# ------------------------------------------------------------------------------
# HR-Buddy backend environment template (example values)
# ------------------------------------------------------------------------------
# 1) Copy this file to .env
# 2) Replace all example secrets/keys/passwords before real use
# 3) Quick local run (no external service):
#    - OTP_DELIVERY_PROVIDER=console
#    - ATTACHMENT_STORAGE_PROVIDER=local
# 4) Prod-like local test (real providers):
#    - OTP_DELIVERY_PROVIDER=smtp
#    - ATTACHMENT_STORAGE_PROVIDER=b2
# ------------------------------------------------------------------------------

NODE_ENV=development
RUNTIME_ENV=development
PORT=3001
CORS_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
DATABASE_URL=postgresql://hrbuddy:hrbuddy_pass@localhost:5433/hr_buddy?schema=public
GEO_DATASET_PATH=
READINESS_STRICT_PROVIDERS=false
RUNTIME_CONFIG_STRICT=false
TRUST_PROXY=
HEALTH_CHECK_TOKEN=

# OTP
OTP_HASH_SECRET=example-otp-hash-secret-please-change-2026
OTP_CODE_TTL_MINUTES=5
OTP_SESSION_TTL_MINUTES=30
OTP_MAX_ATTEMPTS=5
OTP_SEND_COOLDOWN_SECONDS=60
OTP_MAX_SEND_PER_HOUR=6

# Provider: console | smtp | webhook
OTP_DELIVERY_PROVIDER=console

# Used when OTP_DELIVERY_PROVIDER=smtp
OTP_SMTP_HOST=smtp.gmail.com
OTP_SMTP_PORT=465
OTP_SMTP_SECURE=true
OTP_SMTP_USERNAME=example.sender@gmail.com
OTP_SMTP_APP_PASSWORD=abcdefghijklmnop
OTP_SMTP_FROM_EMAIL=example.sender@gmail.com
OTP_SMTP_TIMEOUT_MS=8000

# Used when OTP_DELIVERY_PROVIDER=webhook
OTP_WEBHOOK_URL=https://otp-gateway.example.com/otp/send
OTP_WEBHOOK_API_KEY=example-otp-webhook-api-key
OTP_WEBHOOK_SIGNING_SECRET=example-otp-webhook-signing-secret-32chars
OTP_WEBHOOK_INCLUDE_PHONE=false
OTP_WEBHOOK_TIMEOUT_MS=5000
OTP_WEBHOOK_MAX_RETRIES=2
OTP_WEBHOOK_RETRY_DELAY_MS=200

# Request dedupe
REQUEST_DEDUPE_WINDOW_SECONDS=30
REQUEST_CREATE_USE_DB_LOCK=true

# Abuse Protection / Rate Limiting
ABUSE_PROTECTION_ENABLED=true
ABUSE_PROTECTION_STORE=memory
# Production recommendation: set ABUSE_PROTECTION_STORE=postgres
ABUSE_PROTECTION_MAX_ENTRIES=50000
ABUSE_PROTECTION_POSTGRES_RETRY_AFTER_SECONDS=30
ABUSE_PROTECTION_POSTGRES_CLEANUP_INTERVAL_SECONDS=300
ABUSE_PROTECTION_POSTGRES_RETENTION_HOURS=48
# Keep true for production-safety (fail-closed when postgres rate-limit store is unavailable)
ABUSE_PROTECTION_POSTGRES_FAIL_CLOSED_IN_PRODUCTION=true
RATE_LIMIT_OTP_SEND_WINDOW_SECONDS=60
RATE_LIMIT_OTP_SEND_MAX_REQUESTS=5
RATE_LIMIT_OTP_SEND_BLOCK_SECONDS=300
RATE_LIMIT_OTP_VERIFY_WINDOW_SECONDS=60
RATE_LIMIT_OTP_VERIFY_MAX_REQUESTS=10
RATE_LIMIT_OTP_VERIFY_BLOCK_SECONDS=300
RATE_LIMIT_ADMIN_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_ADMIN_LOGIN_MAX_REQUESTS=10
RATE_LIMIT_ADMIN_LOGIN_BLOCK_SECONDS=600
RATE_LIMIT_REQUEST_CREATE_WINDOW_SECONDS=60
RATE_LIMIT_REQUEST_CREATE_MAX_REQUESTS=30
RATE_LIMIT_REQUEST_CREATE_BLOCK_SECONDS=120
RATE_LIMIT_MESSENGER_LINK_WINDOW_SECONDS=60
RATE_LIMIT_MESSENGER_LINK_MAX_REQUESTS=30
RATE_LIMIT_MESSENGER_LINK_BLOCK_SECONDS=120

# Attachments
ATTACHMENT_UPLOAD_TICKET_SECRET=example-attachment-upload-ticket-secret-please-change
ATTACHMENT_UPLOAD_TICKET_TTL_SECONDS=900
ATTACHMENT_DOWNLOAD_URL_TTL_SECONDS=900

# Provider: local | b2 | webhook
ATTACHMENT_STORAGE_PROVIDER=local

# Used when ATTACHMENT_STORAGE_PROVIDER=local
ATTACHMENT_STORAGE_BASE_URL=http://localhost:3001/storage/mock

# Used when ATTACHMENT_STORAGE_PROVIDER=b2
ATTACHMENT_B2_BUCKET_NAME=hrbuddy-attachments-example
ATTACHMENT_B2_S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
ATTACHMENT_B2_REGION=us-west-004
ATTACHMENT_B2_ACCESS_KEY_ID=exampleb2keyid000000000001
ATTACHMENT_B2_SECRET_ACCESS_KEY=exampleB2ApplicationKey1234567890
ATTACHMENT_B2_MAX_PRESIGN_TTL_SECONDS=3600

# Used when ATTACHMENT_STORAGE_PROVIDER=webhook
ATTACHMENT_STORAGE_WEBHOOK_URL=https://attachment-gateway.example.com/presign
ATTACHMENT_STORAGE_WEBHOOK_API_KEY=example-attachment-webhook-api-key
ATTACHMENT_STORAGE_WEBHOOK_SIGNING_SECRET=example-attachment-webhook-signing-secret-32chars
ATTACHMENT_STORAGE_WEBHOOK_TIMEOUT_MS=5000
ATTACHMENT_STORAGE_WEBHOOK_MAX_RETRIES=2
ATTACHMENT_STORAGE_WEBHOOK_RETRY_DELAY_MS=200

# Messenger Magic Link
MESSENGER_MAGIC_LINK_SECRET=example-magic-link-secret-please-change-2026
MESSENGER_MAGIC_LINK_TTL_HOURS=72
MESSENGER_MUTATION_REPLAY_WINDOW_SECONDS=5
MESSENGER_MAGIC_LINK_BASE_URL=http://localhost:3000/messenger

# Admin Auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
ADMIN_SESSION_SECRET=example-admin-session-secret-please-change-2026
ADMIN_SESSION_TTL_MINUTES=480

# Data Retention / Purge
RETENTION_ENABLED=false
RETENTION_RUN_ON_STARTUP=false
RETENTION_INTERVAL_HOURS=24
RETENTION_USE_DB_LOCK=true
RETENTION_DB_LOCK_KEY=48151623
RETENTION_OTP_SESSIONS_DAYS=7
RETENTION_EMPLOYEE_SESSIONS_DAYS=7
RETENTION_NOTIFICATIONS_DAYS=180
RETENTION_ACTIVITY_LOGS_DAYS=365
RETENTION_ADMIN_SESSIONS_DAYS=30

# PDPA
PDPA_ANONYMIZE_MIN_CLOSED_DAYS=30

